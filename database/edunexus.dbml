  incident_type varchar

  description text

  action_taken text
}

//////////////////////////////////////////////////////
// HOSTEL MAINTENANCE
//////////////////////////////////////////////////////

Table hostel_maintenance_requests {
  request_id int [pk]

  hostel_id int

  room_id int

  reported_by int

  issue_type varchar

  description text

  status varchar

  reported_at timestamp
}

//////////////////////////////////////////////////////
// VISITOR LOGS
//////////////////////////////////////////////////////

Table hostel_visitors {
  visitor_id int [pk]

  student_id int

  visitor_name varchar

  relationship varchar

  national_id varchar

  phone varchar

  visit_date timestamp

  approved_by int
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: hostels.school_id > schools.school_id

Ref: rooms.hostel_id > hostels.hostel_id

Ref: beds.room_id > rooms.room_id

Ref: hostel_staff.hostel_id > hostels.hostel_id
Ref: hostel_staff.staff_id > staff.staff_id

Ref: boarding_students.student_id > students.student_id

Ref: bed_assignments.student_id > students.student_id
Ref: bed_assignments.bed_id > beds.bed_id
Ref: bed_assignments.assigned_by > users.user_id

Ref: hostel_roll_calls.hostel_id > hostels.hostel_id
Ref: hostel_roll_calls.conducted_by > users.user_id

Ref: hostel_roll_call_attendance.roll_call_id > hostel_roll_calls.roll_call_id
Ref: hostel_roll_call_attendance.student_id > students.student_id

Ref: leave_out_requests.student_id > students.student_id
Ref: leave_out_requests.approved_by > users.user_id

Ref: hostel_inspections.hostel_id > hostels.hostel_id
Ref: hostel_inspections.inspected_by > users.user_id

Ref: hostel_inspection_results.inspection_id > hostel_inspections.inspection_id
Ref: hostel_inspection_results.student_id > students.student_id

Ref: hostel_discipline_records.student_id > students.student_id
Ref: hostel_discipline_records.reported_by > users.user_id

Ref: hostel_maintenance_requests.hostel_id > hostels.hostel_id
Ref: hostel_maintenance_requests.room_id > rooms.room_id
Ref: hostel_maintenance_requests.reported_by > users.user_id

Ref: hostel_visitors.student_id > students.student_id
Ref: hostel_visitors.approved_by > users.user_id


