}

//////////////////////////////////////////////////////
// LEAVE OUT REQUESTS
//////////////////////////////////////////////////////

Table leave_out_requests {
  leave_request_id int [pk]

  student_id int

  approved_by int

  departure_time timestamp

  expected_return_time timestamp

