//////////////////////////////////////////////////////
// EDUNEXUS CORE FOUNDATION
//////////////////////////////////////////////////////

Table schools {
  school_id int [pk]

  school_name varchar
  school_type varchar
  school_category varchar

  school_motto varchar

  school_email varchar
  school_phone varchar

  school_address text

  county varchar
  country varchar

  website varchar

  created_at timestamp
  updated_at timestamp
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

Table users {
  user_id int [pk]

  school_id int

  first_name varchar
  middle_name varchar
  last_name varchar

  email varchar
  phone varchar

  password_hash varchar

  gender varchar
  date_of_birth date

  profile_photo text

  status varchar

  created_at timestamp
  updated_at timestamp
}

//////////////////////////////////////////////////////
// ROLES
//////////////////////////////////////////////////////

Table roles {
  role_id int [pk]

  role_name varchar
  role_description text
}

//////////////////////////////////////////////////////
// USER ROLES
//////////////////////////////////////////////////////

Table user_roles {
  user_role_id int [pk]

  user_id int
  role_id int
}

//////////////////////////////////////////////////////
// PERMISSIONS
//////////////////////////////////////////////////////

Table permissions {
  permission_id int [pk]

  permission_name varchar
  description text
}

//////////////////////////////////////////////////////
// ROLE PERMISSIONS
//////////////////////////////////////////////////////

Table role_permissions {
  role_permission_id int [pk]

  role_id int
  permission_id int
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: users.school_id > schools.school_id

Ref: user_roles.user_id > users.user_id
Ref: user_roles.role_id > roles.role_id

Ref: role_permissions.role_id > roles.role_id
Ref: role_permissions.permission_id > permissions.permission_id

//////////////////////////////////////////////////////
// EDUNEXUS LAYER 2
// ACADEMIC SYSTEM
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// ACADEMIC YEARS
//////////////////////////////////////////////////////

Table academic_years {
  academic_year_id int [pk]

  school_id int

  year_name varchar
  start_date date
  end_date date

  status varchar
}

//////////////////////////////////////////////////////
// TERMS
//////////////////////////////////////////////////////

Table terms {
  term_id int [pk]

  academic_year_id int

  term_name varchar

  start_date date
  end_date date

  status varchar
}

//////////////////////////////////////////////////////
// DEPARTMENTS
//////////////////////////////////////////////////////

Table departments {
  department_id int [pk]

  school_id int

  department_name varchar
  description text
}

//////////////////////////////////////////////////////
// STAFF
//////////////////////////////////////////////////////

Table staff {
  staff_id int [pk]

  user_id int

  employee_number varchar

  employment_date date

  department_id int

  qualification varchar
  specialization varchar

  status varchar
}

//////////////////////////////////////////////////////
// CLASSES
//////////////////////////////////////////////////////

Table classes {
  class_id int [pk]

  school_id int

  class_name varchar
  stream varchar

  academic_year_id int

  class_teacher_id int
}

//////////////////////////////////////////////////////
// STUDENTS
//////////////////////////////////////////////////////

Table students {
  student_id int [pk]

  user_id int

  admission_number varchar

  admission_date date

  expected_graduation_year int

  status varchar
}

//////////////////////////////////////////////////////
// STUDENT CLASS HISTORY
//////////////////////////////////////////////////////

Table student_classes {
  student_class_id int [pk]

  student_id int

  class_id int

  academic_year_id int

  start_date date
  end_date date

  status varchar
}

//////////////////////////////////////////////////////
// PARENTS
//////////////////////////////////////////////////////

Table parents {
  parent_id int [pk]

  user_id int

  occupation varchar
  employer varchar

  relationship_type varchar
}

//////////////////////////////////////////////////////
// STUDENT PARENTS
//////////////////////////////////////////////////////

Table student_parents {
  student_parent_id int [pk]

  student_id int

  parent_id int
}

//////////////////////////////////////////////////////
// SUBJECTS
//////////////////////////////////////////////////////

Table subjects {
  subject_id int [pk]

  school_id int

  subject_name varchar
  subject_code varchar

  department_id int
}

//////////////////////////////////////////////////////
// TEACHER SUBJECTS
//////////////////////////////////////////////////////

Table teacher_subjects {
  teacher_subject_id int [pk]

  staff_id int

  subject_id int
}

//////////////////////////////////////////////////////
// ASSIGNMENTS
//////////////////////////////////////////////////////

Table assignments {
  assignment_id int [pk]

  subject_id int

  staff_id int

  class_id int

  title varchar
  description text

  due_date date

  created_at timestamp
}

//////////////////////////////////////////////////////
// STUDENT ASSIGNMENTS
//////////////////////////////////////////////////////

Table student_assignments {
  student_assignment_id int [pk]

  assignment_id int

  student_id int

  submission_date timestamp

  score decimal

  feedback text
}

//////////////////////////////////////////////////////
// EXAMS
//////////////////////////////////////////////////////

Table exams {
  exam_id int [pk]

  school_id int

  class_id int

  term_id int

  exam_name varchar

  exam_type varchar

  exam_date date

  is_past_paper boolean
}

//////////////////////////////////////////////////////
// RESULTS
//////////////////////////////////////////////////////

Table results {
  result_id int [pk]

  exam_id int

  student_id int

  subject_id int

  marks decimal

  grade varchar

  remarks varchar
}

//////////////////////////////////////////////////////
// LEARNING RESOURCES
//////////////////////////////////////////////////////

Table resources {
  resource_id int [pk]

  subject_id int

  uploaded_by int

  title varchar

  resource_type varchar

  file_url text

  created_at timestamp
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: academic_years.school_id > schools.school_id

Ref: terms.academic_year_id > academic_years.academic_year_id

Ref: departments.school_id > schools.school_id

Ref: staff.user_id > users.user_id
Ref: staff.department_id > departments.department_id

Ref: classes.school_id > schools.school_id
Ref: classes.academic_year_id > academic_years.academic_year_id
Ref: classes.class_teacher_id > staff.staff_id

Ref: students.user_id > users.user_id

Ref: student_classes.student_id > students.student_id
Ref: student_classes.class_id > classes.class_id
Ref: student_classes.academic_year_id > academic_years.academic_year_id

Ref: parents.user_id > users.user_id

Ref: student_parents.student_id > students.student_id
Ref: student_parents.parent_id > parents.parent_id

Ref: subjects.school_id > schools.school_id
Ref: subjects.department_id > departments.department_id

Ref: teacher_subjects.staff_id > staff.staff_id
Ref: teacher_subjects.subject_id > subjects.subject_id

Ref: assignments.subject_id > subjects.subject_id
Ref: assignments.staff_id > staff.staff_id
Ref: assignments.class_id > classes.class_id

Ref: student_assignments.assignment_id > assignments.assignment_id
Ref: student_assignments.student_id > students.student_id

Ref: exams.school_id > schools.school_id
Ref: exams.class_id > classes.class_id
Ref: exams.term_id > terms.term_id

Ref: results.exam_id > exams.exam_id
Ref: results.student_id > students.student_id
Ref: results.subject_id > subjects.subject_id

Ref: resources.subject_id > subjects.subject_id
Ref: resources.uploaded_by > users.user_id

//////////////////////////////////////////////////////
// EDUNEXUS CORE ACADEMIC EXTENSIONS
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// SCHOOL SETTINGS
//////////////////////////////////////////////////////

Table school_settings {
setting_id int [pk]

school_id int

setting_key varchar
setting_value text

created_at timestamp
}

//////////////////////////////////////////////////////
// ACADEMIC CALENDAR EVENTS
//////////////////////////////////////////////////////

Table academic_events {
event_id int [pk]

school_id int
term_id int

event_name varchar
event_date date

event_type varchar

description text

created_at timestamp
}

//////////////////////////////////////////////////////
// STUDENT DOCUMENTS
//////////////////////////////////////////////////////

Table student_documents {
document_id int [pk]

student_id int

document_name varchar
document_type varchar

file_url text

uploaded_by int

uploaded_at timestamp
}

//////////////////////////////////////////////////////
// TIMETABLES
//////////////////////////////////////////////////////

Table timetables {
timetable_id int [pk]

school_id int
academic_year_id int
term_id int
class_id int

created_by int

created_at timestamp
}

//////////////////////////////////////////////////////
// TIMETABLE ENTRIES
//////////////////////////////////////////////////////

Table timetable_entries {
entry_id int [pk]

timetable_id int

subject_id int
teacher_id int

room_name varchar

day_of_week varchar

start_time time
end_time time
}

//////////////////////////////////////////////////////
// MEDIA FILES
//////////////////////////////////////////////////////

Table media_files {
file_id int [pk]

school_id int

uploaded_by int

file_name varchar
file_type varchar

file_url text

created_at timestamp
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: school_settings.school_id > schools.school_id

Ref: academic_events.school_id > schools.school_id
Ref: academic_events.term_id > terms.term_id

Ref: student_documents.student_id > students.student_id
Ref: student_documents.uploaded_by > users.user_id

Ref: timetables.school_id > schools.school_id
Ref: timetables.academic_year_id > academic_years.academic_year_id
Ref: timetables.term_id > terms.term_id
Ref: timetables.class_id > classes.class_id
Ref: timetables.created_by > users.user_id

Ref: timetable_entries.timetable_id > timetables.timetable_id
Ref: timetable_entries.subject_id > subjects.subject_id
Ref: timetable_entries.teacher_id > staff.staff_id

Ref: media_files.school_id > schools.school_id
Ref: media_files.uploaded_by > users.user_id


//////////////////////////////////////////////////////
// EDUNEXUS LAYER 3
// COMMUNICATION SYSTEM
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// CONVERSATIONS
//////////////////////////////////////////////////////

Table conversations {
  conversation_id int [pk]

  school_id int

  conversation_name varchar

  conversation_type varchar

  created_by int

  created_at timestamp
}

//////////////////////////////////////////////////////
// CONVERSATION PARTICIPANTS
//////////////////////////////////////////////////////

Table conversation_participants {
  participant_id int [pk]

  conversation_id int

  user_id int

  joined_at timestamp
}

//////////////////////////////////////////////////////
// MESSAGES
//////////////////////////////////////////////////////

Table messages {
  message_id int [pk]

  conversation_id int

  sender_id int

  message_content text

  attachment_url text

  message_type varchar

  created_at timestamp
}

//////////////////////////////////////////////////////
// MESSAGE READS
//////////////////////////////////////////////////////

Table message_reads {
  message_read_id int [pk]

  message_id int

  user_id int

  read_at timestamp
}

//////////////////////////////////////////////////////
// ANNOUNCEMENTS
//////////////////////////////////////////////////////

Table announcements {
  announcement_id int [pk]

  school_id int

  created_by int

  title varchar

  content text

  target_audience varchar

  created_at timestamp
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

Table notifications {
  notification_id int [pk]

  user_id int

  title varchar

  message text

  notification_type varchar

  is_read boolean

  created_at timestamp
}

//////////////////////////////////////////////////////
// VIDEO MEETINGS
//////////////////////////////////////////////////////

Table meetings {
  meeting_id int [pk]

  school_id int

  created_by int

  title varchar

  description text

  meeting_link text

  meeting_date timestamp

  status varchar
}

//////////////////////////////////////////////////////
// MEETING PARTICIPANTS
//////////////////////////////////////////////////////

Table meeting_participants {
  meeting_participant_id int [pk]

  meeting_id int

  user_id int

  joined_at timestamp
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: conversations.school_id > schools.school_id
Ref: conversations.created_by > users.user_id

Ref: conversation_participants.conversation_id > conversations.conversation_id
Ref: conversation_participants.user_id > users.user_id

Ref: messages.conversation_id > conversations.conversation_id
Ref: messages.sender_id > users.user_id

Ref: message_reads.message_id > messages.message_id
Ref: message_reads.user_id > users.user_id

Ref: announcements.school_id > schools.school_id
Ref: announcements.created_by > users.user_id

Ref: notifications.user_id > users.user_id

Ref: meetings.school_id > schools.school_id
Ref: meetings.created_by > users.user_id

Ref: meeting_participants.meeting_id > meetings.meeting_id
Ref: meeting_participants.user_id > users.user_id

//////////////////////////////////////////////////////
// EDUNEXUS LAYER 4
// FINANCE MANAGEMENT SYSTEM
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// FEE CATEGORIES
//////////////////////////////////////////////////////

Table fee_categories {
  fee_category_id int [pk]

  school_id int

  category_name varchar

  description text

  created_at timestamp
}

//////////////////////////////////////////////////////
// FEE STRUCTURES
//////////////////////////////////////////////////////

Table fee_structures {
  fee_structure_id int [pk]

  school_id int

  class_id int

  fee_category_id int

  academic_year_id int

  term_id int

  amount decimal

  created_at timestamp
}

//////////////////////////////////////////////////////
// STUDENT INVOICES
//////////////////////////////////////////////////////

Table student_invoices {
  invoice_id int [pk]

  student_id int

  academic_year_id int

  term_id int

  invoice_number varchar

  total_amount decimal

  invoice_status varchar

  created_at timestamp
}

//////////////////////////////////////////////////////
// INVOICE ITEMS
//////////////////////////////////////////////////////

Table invoice_items {
  invoice_item_id int [pk]

  invoice_id int

  fee_category_id int

  amount decimal
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

Table payments {
  payment_id int [pk]

  student_id int

  invoice_id int

  amount decimal

  payment_method varchar

  transaction_reference varchar

  payment_date timestamp

  recorded_by int
}

//////////////////////////////////////////////////////
// RECEIPTS
//////////////////////////////////////////////////////

Table receipts {
  receipt_id int [pk]

  payment_id int

  receipt_number varchar

  issued_at timestamp
}

//////////////////////////////////////////////////////
// SCHOLARSHIPS
//////////////////////////////////////////////////////

Table scholarships {
  scholarship_id int [pk]

  school_id int

  scholarship_name varchar

  sponsor varchar

  description text
}

//////////////////////////////////////////////////////
// STUDENT SCHOLARSHIPS
//////////////////////////////////////////////////////

Table student_scholarships {
  student_scholarship_id int [pk]

  student_id int

  scholarship_id int

  amount decimal

  start_date date

  end_date date
}

//////////////////////////////////////////////////////
// FEE WAIVERS
//////////////////////////////////////////////////////

Table fee_waivers {
  waiver_id int [pk]

  student_id int

  amount decimal

  reason text

  approved_by int

  approved_at timestamp
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: fee_categories.school_id > schools.school_id

Ref: fee_structures.school_id > schools.school_id
Ref: fee_structures.class_id > classes.class_id
Ref: fee_structures.fee_category_id > fee_categories.fee_category_id
Ref: fee_structures.academic_year_id > academic_years.academic_year_id
Ref: fee_structures.term_id > terms.term_id

Ref: student_invoices.student_id > students.student_id
Ref: student_invoices.academic_year_id > academic_years.academic_year_id
Ref: student_invoices.term_id > terms.term_id

Ref: invoice_items.invoice_id > student_invoices.invoice_id
Ref: invoice_items.fee_category_id > fee_categories.fee_category_id

Ref: payments.student_id > students.student_id
Ref: payments.invoice_id > student_invoices.invoice_id
Ref: payments.recorded_by > users.user_id

Ref: receipts.payment_id > payments.payment_id

Ref: scholarships.school_id > schools.school_id

Ref: student_scholarships.student_id > students.student_id
Ref: student_scholarships.scholarship_id > scholarships.scholarship_id

Ref: fee_waivers.student_id > students.student_id
Ref: fee_waivers.approved_by > users.user_id

//////////////////////////////////////////////////////
// EDUNEXUS LAYER 5
// LIBRARY & BOOK STORE MANAGEMENT
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// BOOK CATEGORIES
//////////////////////////////////////////////////////

Table book_categories {
  category_id int [pk]

  school_id int

  category_name varchar

  description text
}

//////////////////////////////////////////////////////
// LIBRARY BOOKS
//////////////////////////////////////////////////////

Table books {
  book_id int [pk]

  school_id int

  category_id int

  isbn varchar

  title varchar

  author varchar

  publisher varchar

  publication_year int

  edition varchar

  description text

  total_copies int

  available_copies int

  created_at timestamp
}

//////////////////////////////////////////////////////
// PHYSICAL BOOK COPIES
//////////////////////////////////////////////////////

Table book_copies {
  copy_id int [pk]

  book_id int

  accession_number varchar

  barcode varchar

  status varchar
}

//////////////////////////////////////////////////////
// LIBRARY LOANS
//////////////////////////////////////////////////////

Table book_loans {
  loan_id int [pk]

  copy_id int

  student_id int

  issued_by int

  issue_date date

  due_date date

  return_date date

  status varchar
}

//////////////////////////////////////////////////////
// BOOK CONDITION CHECKS
//////////////////////////////////////////////////////

Table book_condition_checks {
  check_id int [pk]

  loan_id int

  checked_by int

  condition_status varchar

  notes text

  checked_at timestamp
}

//////////////////////////////////////////////////////
// BOOK RESERVATIONS
//////////////////////////////////////////////////////

Table book_reservations {
  reservation_id int [pk]

  book_id int

  student_id int

  reservation_date timestamp

  status varchar
}

//////////////////////////////////////////////////////
// LIBRARY FINES
//////////////////////////////////////////////////////

Table library_fines {
  fine_id int [pk]

  loan_id int

  student_id int

  amount decimal

  reason varchar

  paid_status varchar

  created_at timestamp
}

//////////////////////////////////////////////////////
// DIGITAL LIBRARY
//////////////////////////////////////////////////////

Table digital_resources {
  digital_resource_id int [pk]

  school_id int

  uploaded_by int

  title varchar

  resource_type varchar

  file_url text

  description text

  created_at timestamp
}

//////////////////////////////////////////////////////
// BOOK STORE ITEMS
//////////////////////////////////////////////////////

Table book_store_items {
  store_item_id int [pk]

  school_id int

  subject_id int

  isbn varchar

  title varchar

  publisher varchar

  edition varchar

  total_quantity int

  available_quantity int

  created_at timestamp
}

//////////////////////////////////////////////////////
// BOOK STORE ISSUES
//////////////////////////////////////////////////////

Table book_store_issues {
  issue_id int [pk]

  store_item_id int

  student_id int

  issued_by int

  issue_date date

  expected_return_date date

  actual_return_date date

  status varchar
}

//////////////////////////////////////////////////////
// LOST / REPLACEMENT TRACKING
//////////////////////////////////////////////////////

Table book_replacements {
  replacement_id int [pk]

  issue_id int

  student_id int

  replacement_method varchar

  replacement_notes text

  approved_by int

  replacement_date timestamp
}

//////////////////////////////////////////////////////
// RELATIONSHIPS
//////////////////////////////////////////////////////

Ref: book_categories.school_id > schools.school_id

Ref: books.school_id > schools.school_id
Ref: books.category_id > book_categories.category_id

Ref: book_copies.book_id > books.book_id

Ref: book_loans.copy_id > book_copies.copy_id
Ref: book_loans.student_id > students.student_id
Ref: book_loans.issued_by > users.user_id

Ref: book_condition_checks.loan_id > book_loans.loan_id
Ref: book_condition_checks.checked_by > users.user_id

Ref: book_reservations.book_id > books.book_id
Ref: book_reservations.student_id > students.student_id

Ref: library_fines.loan_id > book_loans.loan_id
Ref: library_fines.student_id > students.student_id

Ref: digital_resources.school_id > schools.school_id
Ref: digital_resources.uploaded_by > users.user_id

Ref: book_store_items.school_id > schools.school_id
Ref: book_store_items.subject_id > subjects.subject_id

Ref: book_store_issues.store_item_id > book_store_items.store_item_id
Ref: book_store_issues.student_id > students.student_id
Ref: book_store_issues.issued_by > users.user_id

Ref: book_replacements.issue_id > book_store_issues.issue_id
Ref: book_replacements.student_id > students.student_id
Ref: book_replacements.approved_by > users.user_id

//////////////////////////////////////////////////////
// EDUNEXUS LAYER 6
// HOSTEL & BOARDING MANAGEMENT
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// HOSTELS
//////////////////////////////////////////////////////

Table hostels {
  hostel_id int [pk]

  school_id int

  hostel_name varchar

  hostel_type varchar
  gender_type varchar

  capacity int

  description text

  created_at timestamp
}

//////////////////////////////////////////////////////
// ROOMS
//////////////////////////////////////////////////////

Table rooms {
  room_id int [pk]

  hostel_id int

  room_name varchar

  floor_number int

  capacity int
}

//////////////////////////////////////////////////////
// BEDS
//////////////////////////////////////////////////////

Table beds {
  bed_id int [pk]

  room_id int

  bed_number varchar

  status varchar
}

//////////////////////////////////////////////////////
// HOSTEL STAFF
//////////////////////////////////////////////////////

Table hostel_staff {
  hostel_staff_id int [pk]

  hostel_id int

  staff_id int

  role varchar

  assigned_date date
}

//////////////////////////////////////////////////////
// BOARDING STUDENTS
//////////////////////////////////////////////////////

Table boarding_students {
  boarding_student_id int [pk]

  student_id int

  boarding_status varchar

