  application_link text
  application_deadline date

  start_date date
  end_date date

  eligibility text
  benefits text

  status varchar

  // RAW INGESTION CONTROL (for Opportunet pipeline)
  source_type varchar        // scraped, manual, api
  external_id varchar        // original ID from provider
  is_verified boolean

  // AI / OPPORTUNET LAYER
  embedding vector           // optional AI semantic search
  match_score_avg decimal

  created_at timestamp
  updated_at timestamp
}
