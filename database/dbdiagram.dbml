Layer 1: Core Foundation
Table schools {
  school_id int [pk]
  school_name varchar
  school_type varchar
  school_motto varchar
  school_email varchar
  school_phone varchar
  school_address text
  county varchar
  country varchar
  website varchar
  created_at timestamp
  updated_at timestamp
}

Table users {
  user_id int [pk]
  school_id int
  first_name varchar
  middle_name varchar
  last_name varchar
  email varchar
  phone varchar
  password_hash varchar
  gender varchar
  date_of_birth date
  profile_photo text
  status varchar
  created_at timestamp
  updated_at timestamp
}

Table roles {
  role_id int [pk]
  role_name varchar
  role_description text
}

Table permissions {
  permission_id int [pk]
  permission_name varchar
  description text
}

Table user_roles {
  user_role_id int [pk]
  user_id int
  role_id int
}

Table role_permissions {
  role_permission_id int [pk]
  role_id int
  permission_id int
}

Ref: users.school_id > schools.school_id

Ref: user_roles.user_id > users.user_id
Ref: user_roles.role_id > roles.role_id

Ref: role_permissions.role_id > roles.role_id
Ref: role_permissions.permission_id > permissions.permission_id

## Layer 2: Student Information System

Table students {
  student_id int [pk]
  user_id int
  admission_number varchar
  current_class_id int
  admission_date date
  expected_graduation_year int
  status varchar
}

Table parents {
  parent_id int [pk]
  user_id int
  occupation varchar
  employer varchar
  relationship_type varchar
}

Table student_parents {
  student_parent_id int [pk]
  student_id int
  parent_id int
}

Table staff {
  staff_id int [pk]
  user_id int
  employee_number varchar
  employment_date date
  department_id int
  qualification varchar
  specialization varchar
}

Ref: students.user_id > users.user_id
Ref: parents.user_id > users.user_id
Ref: staff.user_id > users.user_id

Ref: student_parents.student_id > students.student_id
Ref: student_parents.parent_id > parents.parent_id

## Layer 3: Academic Module
Table departments {
  department_id int [pk]
  department_name varchar
  description text
}

Table classes {
  class_id int [pk]
  class_name varchar
  stream varchar
  academic_year int
  class_teacher_id int
}

Table subjects {
  subject_id int [pk]
  subject_name varchar
  subject_code varchar
  department_id int
}

Table teacher_subjects {
  teacher_subject_id int [pk]
  staff_id int
  subject_id int
}

Ref: staff.department_id > departments.department_id

Ref: subjects.department_id > departments.department_id

Ref: students.current_class_id > classes.class_id

Ref: classes.class_teacher_id > staff.staff_id

Ref: teacher_subjects.staff_id > staff.staff_id
Ref: teacher_subjects.subject_id > subjects.subject_id


## ACADEMIC YEARS
Table academic_years {
  academic_year_id int [pk]
  school_id int
  year_name varchar
  start_date date
  end_date date
  status varchar
}

Ref: academic_years.school_id > schools.school_id

## TERMS
Table terms {
  term_id int [pk]
  academic_year_id int
  term_name varchar
  start_date date
  end_date date
}

Ref: terms.academic_year_id > academic_years.academic_year_id

## STUDENT CLASS HISTORY
Table student_classes {
  student_class_id int [pk]
  student_id int
  class_id int
  academic_year_id int
  term_id int
  date_joined date
  date_left date
}

Ref: student_classes.student_id > students.student_id
Ref: student_classes.class_id > classes.class_id
Ref: student_classes.academic_year_id > academic_years.academic_year_id
Ref: student_classes.term_id > terms.term_id

## CONVERSATION PARTICIPANTS
Table conversations {
  conversation_id int [pk]
  conversation_type varchar
}

Table conversation_participants {
  participant_id int [pk]
  conversation_id int
  user_id int
  joined_at timestamp
}

Table messages {
  message_id int [pk]
  conversation_id int
  sender_id int
  message_content text
  created_at timestamp
}

Ref: conversation_participants.conversation_id > conversations.conversation_id
Ref: conversation_participants.user_id > users.user_id

Ref: messages.conversation_id > conversations.conversation_id
Ref: messages.sender_id > users.user_id

## NOTIFICATIONS
Table notifications {
  notification_id int [pk]
  user_id int
  title varchar
  message text
  notification_type varchar
  is_read boolean
  created_at timestamp
}

Ref: notifications.user_id > users.user_id

## AUDIT LOGS
Table audit_logs {
  audit_log_id int [pk]
  user_id int
  action varchar
  module_name varchar
  record_id int
  created_at timestamp
}

Ref: audit_logs.user_id > users.user_id

## ASSIGNMENTS
Table assignments {
  assignment_id int [pk]
  subject_id int
  staff_id int
  class_id int
  title varchar
  description text
  due_date date
  created_at timestamp
}

Ref: assignments.subject_id > subjects.subject_id
Ref: assignments.staff_id > staff.staff_id
Ref: assignments.class_id > classes.class_id

## STUDENT ASSIGNMENTS
Table student_assignments {
  student_assignment_id int [pk]
  assignment_id int
  student_id int
  submission_date timestamp
  score decimal
  feedback text
}

Ref: student_assignments.assignment_id > assignments.assignment_id
Ref: student_assignments.student_id > students.student_id

## EXAMS
Table exams {
  exam_id int [pk]
  term_id int
  class_id int
  subject_id int
  created_by int

  exam_name varchar
  exam_type varchar

  total_marks decimal

  exam_date date

  is_past_paper boolean

  created_at timestamp
}

Ref: exams.term_id > terms.term_id
Ref: exams.class_id > classes.class_id
Ref: exams.subject_id > subjects.subject_id
Ref: exams.created_by > staff.staff_id


## RESULTS
Table results {
  result_id int [pk]
  exam_id int
  student_id int
  subject_id int
  marks decimal
  grade varchar
  remarks varchar
}

Ref: results.exam_id > exams.exam_id
Ref: results.student_id > students.student_id
Ref: results.subject_id > subjects.subject_id

## Exam Papers
Table exam_papers {
  exam_paper_id int [pk]

  exam_id int

  file_url text

  file_type varchar

  uploaded_at timestamp
}
Ref: exam_papers.exam_id > exams.exam_id

## Exam Questions

Table exam_questions {
  question_id int [pk]

  exam_id int

  question_number int

  question_text text

  marks decimal
}
Ref: exam_questions.exam_id > exams.exam_id

## Past Papers Repository
Table past_papers {
  past_paper_id int [pk]

  exam_id int

  subject_id int

  class_id int

  year int

  term_id int

  paper_type varchar

  uploaded_at timestamp
}
Ref: past_papers.exam_id > exams.exam_id
Ref: past_papers.subject_id > subjects.subject_id
Ref: past_papers.class_id > classes.class_id
Ref: past_papers.term_id > terms.term_id
